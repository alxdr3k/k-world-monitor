# k-world-monitor — secret reference (DEC-020 Q-047)
#
# Primary secret store: Doppler (see docs/05_RUNBOOK.md "Doppler integration").
# This file is the variable-name reference for ad-hoc / fallback environments
# (debugging, new operator onboarding). Never commit a populated .env — it is
# gitignored.
#
# Usage:
#   doppler run -- bun run ...                   (preferred, Doppler primary)
#   cp .env.example .env && edit .env            (fallback only)
#   bun --env-file=.env run ...                  (fallback execution)

# ---------------------------------------------------------------------------
# LLM vendors (ADR-0023 + DEC-010 multi-vendor routing)
# ---------------------------------------------------------------------------

# OpenAI (default vendor — Tier 0~3 default routing)
OPENAI_API_KEY=

# Anthropic (cross-vendor reviewer + domain override)
ANTHROPIC_API_KEY=

# Google AI Studio (Gemini 2.5 Flash — 탐색 grounding + Tier 3 fallback, optional)
GOOGLE_AI_API_KEY=

# ---------------------------------------------------------------------------
# Cloudflare R2 (permitted artifact storage, ADR-0012 + INFRA-1A.3)
# ---------------------------------------------------------------------------
#
# Variable names match what `src/storage/r2/client.ts` reads.
# Restrict the IAM token to the project bucket via Cloudflare R2 policy.

# Full S3 endpoint URL. For Cloudflare R2:
#   https://<accountid>.r2.cloudflarestorage.com
# Also supports custom domains and S3-compatible mocks (localstack, MinIO).
S3_ENDPOINT=

# R2 access key + secret (S3-compatible)
S3_ACCESS_KEY=
S3_SECRET_KEY=

# Bucket name (single bucket for permitted artifacts)
S3_BUCKET=

# ---------------------------------------------------------------------------
# Neo4j (self-host Community Edition, ADR-0014)
# ---------------------------------------------------------------------------

# bolt://localhost:7687 (default) or custom URI for remote Neo4j.
NEO4J_URI=bolt://localhost:7687

# Username — driver default is "neo4j" but explicit env var is recommended.
# Variable name matches what `src/storage/neo4j/connection.ts` reads.
NEO4J_USER=neo4j

NEO4J_PASSWORD=

# Optional — database name override (default "neo4j").
# NEO4J_DATABASE=neo4j

# Optional pool tuning (DEC-016).
# NEO4J_MAX_POOL_SIZE=10
# NEO4J_ACQ_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# SQLite (local research database)
# ---------------------------------------------------------------------------

# Override path if not using the default `research.db` in cwd.
# SQLITE_PATH=./research.db
